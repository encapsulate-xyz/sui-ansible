# ── Identity ──────────────────────────────────────────────────────────

# Ed25519 TLS private key (PEM file path, DER file path, or inline PEM)
tls-private-key = "{{ hashinode_tls_key_path }}"

# Ed25519 operator private key for signing the node's Sui transactions
operator-private-key = "{{ hashinode_operator_key_path }}"

# Your Sui validator address
validator-address = "{{ sui.hashi.validator_address }}"

# ── Network ───────────────────────────────────────────────────────────

# Local bind address for gRPC+TLS server (default: 0.0.0.0:443)
listen-address = "0.0.0.0:{{ sui.hashi.ports.server_listen_port }}"

# Public URL where other validators can reach this node
endpoint-url = "{{ sui.hashi.external_address }}:{{ sui.hashi.ports.server_listen_port }}"

# Prometheus metrics endpoint (default: 127.0.0.1:9180)
metrics-http-address = "0.0.0.0:{{ sui.hashi.ports.metrics_port }}"

# ── Sui (gRPC v2) ─────────────────────────────────────────────────────

# Sui chain ID — genesis checkpoint digest (Base58).
sui-chain-id = "{{ sui.hashi.sui_chain_id }}"

# Sui gRPC endpoint.
sui-rpc = "{{ sui.hashi.sui_rpc }}"

# ── Bitcoin ───────────────────────────────────────────────────────────

# Bitcoin chain ID — genesis block hash.
bitcoin-chain-id = "{{ sui.hashi.bitcoin_chain_id }}"

# Bitcoin Core RPC endpoint
bitcoin-rpc = "{{ sui.hashi.bitcoin_rpc }}"

# Trusted Bitcoin P2P peers for the embedded BIP-157 light client
bitcoin-trusted-peers = ["{{ sui.hashi.bitcoin_trusted_peers }}"]

# Block height the light client begins syncing from
bitcoin-start-height = {{ hashi_bitcoin_start_height | default(sui.hashi.bitcoin_start_height_default) }}

# ── Storage ───────────────────────────────────────────────────────────

# Local database path
db = "{{ hashinode_data_dir }}/db"

# ── Backup (OpenPGP / Sequoia) ────────────────────────────────────────

# Armored OpenPGP public certificate for encrypted backups
# backup-pgp-cert = "{{ hashinode_backup_pgp_cert_path }}"
backup-pgp-cert = '''
{{ lookup('file', env + '/backup-cert.asc') }}'''

# Backup output directory
backup-dir = "{{ hashinode_backup_dir }}"

# ── Nested tables ─────────────────────────────────────────────────────
# TOML table headers apply to every following key until the next table,
# so keep all root-level settings above this section.

# Hashi package and object IDs
[hashi-ids]
package-id = "{{ sui.hashi.package_id }}"
hashi-object-id = "{{ sui.hashi.hashi_object_id }}"

# RPC authentication: None, UserPass, or CookieFile
[bitcoin-rpc-auth]
UserPass = ["{{ vault.hashi.bitcoin_rpc_user }}", "{{ vault.hashi.bitcoin_rpc_password }}"]

[metrics-push]
push-url = "https://metrics-proxy.testnet.sui.io:8443/publish/metrics"
